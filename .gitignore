# macOS
.DS_Store

# Test outputs
test_*.png

# Temp/debug scripts
/tmp/
*.pyc
__pycache__/

# Private user data — career, profile, PDFs (NEVER commit)
netscan/profile-private.json
netscan/crawl-targets.json
netscan/watchlist.json
car-known-locations.json
*.pdf

# Secrets (systemd units may contain tokens)
# openclaw-gateway.service is tracked as reference (token redacted)
user info/
tmp/

# Internal notes (planning docs, Claude session context — not for repo)
internal_notes_claude.txt
notes/

# Claude Code session data
.claude/

# Live backup from bc250
bc250-backup/

# Old/deprecated files kept for reference
deprecated/

# Article drafts (not for GitHub)
article/
Latex_template-v1.11/
arxiv-submission/
arxiv-submission.zip
texput.log
.vscode/

# Vendored upstream toolkit — referenced via github.com/duggasco/bc250-40cu-unlock,
# not mirrored in this repo.
scripts/40cu-unlock/

# Working notes / per-folder summaries: only the top-level Readme.md is tracked
# documentation. Useful findings are folded into Readme.md, not committed as
# scattered .md files.
**/*.md
!/Readme.md

